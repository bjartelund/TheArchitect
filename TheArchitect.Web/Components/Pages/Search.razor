@page "/search"
@rendermode InteractiveServer
@inject ArchitectApiClient ArchitectApi

<PageTitle>Search – The Architect</PageTitle>

<h1>Search Documents</h1>
<p class="text-muted">Evaluate how queries match the underlying Well-Architected Framework document store.</p>

<div class="mb-4">
    <div class="input-group">
        <input type="text"
               class="form-control"
               placeholder="Enter a search query…"
               @bind="_searchQuery"
               @bind:event="oninput"
               @onkeyup="HandleKeyUp"
               disabled="@_isSearching" />
        <button class="btn btn-primary" @onclick="DoSearch"
                disabled="@(_isSearching || string.IsNullOrWhiteSpace(_searchQuery))">
            @if (_isSearching)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            Search
        </button>
    </div>
    @if (!string.IsNullOrEmpty(_searchError))
    {
        <div class="alert alert-danger mt-2">@_searchError</div>
    }
</div>

@if (_searchResults is not null)
{
    <h5>Results (@_searchResults.Count)</h5>
    @if (_searchResults.Count == 0)
    {
        <p class="text-muted">No results found.</p>
    }
    else
    {
        <div class="list-group mb-4">
            @foreach (var result in _searchResults)
            {
                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <span class="text-truncate me-3 small font-monospace">@result.File</span>
                    <span class="badge bg-primary rounded-pill flex-shrink-0">@result.Score.ToString("F4")</span>
                </div>
            }
        </div>
    }
}

<hr />

<h3>Document Ingestion</h3>
<p class="text-muted">Index all Well-Architected Framework markdown files into the vector store. This may take several minutes.</p>

<button class="btn btn-warning" @onclick="Ingest" disabled="@_isIngesting">
    @if (_isIngesting)
    {
        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
        <span>Ingesting…</span>
    }
    else
    {
        <span>Trigger Ingestion</span>
    }
</button>

@if (!string.IsNullOrEmpty(_ingestError))
{
    <div class="alert alert-danger mt-3">@_ingestError</div>
}

@if (!string.IsNullOrEmpty(_ingestResult))
{
    <pre class="mt-3 p-3 bg-light border rounded small">@_ingestResult</pre>
}

@code {
    private string _searchQuery = string.Empty;
    private bool _isSearching;
    private string? _searchError;
    private List<SearchResultItem>? _searchResults;

    private bool _isIngesting;
    private string? _ingestResult;
    private string? _ingestError;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_isSearching && !string.IsNullOrWhiteSpace(_searchQuery))
            await DoSearch();
    }

    private async Task DoSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;

        _searchError = null;
        _searchResults = null;
        _isSearching = true;

        try
        {
            _searchResults = await ArchitectApi.SearchAsync(_searchQuery);
        }
        catch (Exception ex)
        {
            _searchError = $"Error: {ex.Message}";
        }
        finally
        {
            _isSearching = false;
        }
    }

    private async Task Ingest()
    {
        _ingestError = null;
        _ingestResult = null;
        _isIngesting = true;

        try
        {
            _ingestResult = await ArchitectApi.IngestAsync();
        }
        catch (Exception ex)
        {
            _ingestError = $"Error: {ex.Message}";
        }
        finally
        {
            _isIngesting = false;
        }
    }
}
